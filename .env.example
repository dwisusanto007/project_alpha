# Project Alpha — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ─── App ───────────────────────────────────────
PORT=3000
NODE_ENV=development          # development | staging | production

# ─── Database (Supabase) ───────────────────────
# Get these from: Supabase Dashboard → Settings → Database
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Developer Auth ───────────────────────────
# Credentials untuk login ke developer dashboard (/app)
DEV_EMAIL=your-email@example.com
DEV_PASSWORD=replace-with-strong-password
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# ─── Portal Auth ──────────────────────────────
PORTAL_JWT_SECRET=replace-with-long-random-string
PORTAL_JWT_EXPIRES_IN=7d
MAGIC_LINK_EXPIRES_MINUTES=1440
APP_BASE_URL=http://localhost:3000

# ─── Email (SMTP) ─────────────────────────────
# If SMTP_HOST is not set, magic link URL is logged to console (dev mode)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-gmail-app-password
FROM_EMAIL=noreply@projectalpha.dev